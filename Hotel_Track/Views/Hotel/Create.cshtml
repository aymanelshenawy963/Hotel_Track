@model Hotel

<div class="row mb-3">
    <h2><a href="/Hotel/Index"><i class="bi bi-arrow-left"></i></a> Create New Hotel</h2>
</div>

<div class="row">
    <form asp-action="Create" asp-controller="Hotel" enctype="multipart/form-data" method="post">
        <div class="mb-3">
            <label for="HotelName" class="form-label">Name</label>
            <input class="form-control" asp-for="Name">
            <span asp-validation-for="Name" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label for="HotelLocation" class="form-label">Location</label>
            <input class="form-control" asp-for="Location">
            <span asp-validation-for="Location" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label for="HotelEmail" class="form-label">Email</label>
            <input class="form-control" asp-for="Email">
            <span asp-validation-for="Email" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label for="HotelPhoneNumber" class="form-label">Phone Number</label>
            <input class="form-control" asp-for="PhoneNumber">
            <span asp-validation-for="PhoneNumber" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label for="HotelDescription" class="form-label">Description</label>
            <input class="form-control" asp-for="Description">
            <span asp-validation-for="Description" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label for="HotelImage" class="form-label">Hotel Image</label>
            <input type="file" class="form-control" id="HotelImage" asp-for="ImgUrl" onchange="previewImage(event)">
            <span asp-validation-for="ImgUrl" class="text-warning"></span>
            <img id="imagePreview" src="" alt="Image Preview" style="display:none; margin-top: 10px; max-width: 20%;" />
        </div>
        <div class="mb-3">
            <label for="HotelType" class="form-label">Type</label>
            <select asp-for="HotelType" class="form-control" asp-items="@(new SelectList(ViewBag.HotelType, "Id", "Name"))">
                <option value="">Select Hotel Type</option>
            </select>
            <span asp-validation-for="HotelType" class="text-warning"></span>
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </form>
</div>

<script>
    function previewImage(event) {
        const imagePreview = document.getElementById('imagePreview');
        imagePreview.src = URL.createObjectURL(event.target.files[0]);
        imagePreview.style.display = 'block';
    }
</script>
@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}